# ── Rede de deploy ────────────────────────────────────────────────────────────
# Define qual arquivo de endereços o frontend vai carregar.
# local   → frontend/src/deploy/local.json   (Anvil)
# sepolia → frontend/src/deploy/sepolia.json  (gerado por deploy:sepolia)
REDE_DEPLOY=local

# ── RPC ───────────────────────────────────────────────────────────────────────
# URL do nó RPC — usada pelo frontend e pelos dois scripts de deploy.
# Local (Anvil):     http://127.0.0.1:8545   ← default se não definida
# Sepolia (publico):  https://ethereum-sepolia-rpc.publicnode.com
URL_RPC=http://127.0.0.1:8545

# ── IPFS / Pinata ─────────────────────────────────────────────────────────────
# Obtenha em app.pinata.cloud → API Keys → New Key → JWT
CHAVE_PINATA=

# Gateway Pinata para acesso público aos arquivos.
# Padrão público: https://gateway.pinata.cloud/ipfs
# Gateway dedicado: https://SEU_GATEWAY.mypinata.cloud/ipfs
URL_GATEWAY_PINATA=

# ── Governança ────────────────────────────────────────────────────────────────
# Obrigatórias para deploy:local e deploy:sepolia.
#
# Quórum mínimo de peso de voto para aprovar propostas (em wei).
# Peso de voto = sqrt(total_doado_em_wei).
# Exemplo para quórum equivalente a ~1 ETH doado:
#   sqrt(1_000_000_000_000_000_000) = 1_000_000_000 → QUORUM_MINIMO=1000000000
QUORUM_MINIMO=1

# Período de votação em segundos (ex: 259200 = 3 dias)
PERIODO_VOTACAO=120

# Janela para abrir disputa após entrega, em segundos (ex: 604800 = 7 dias)
JANELA_DISPUTA=120

# Janela para confirmar recebimento após entrega, em segundos (ex: 604800 = 7 dias)
JANELA_CONFIRMACAO=120

# ── Apenas para deploy:sepolia ────────────────────────────────────────────────
# Chave privada da carteira que vai pagar o deploy na Sepolia.
# Obtenha ETH de teste em: https://sepoliafaucet.com
CHAVE_PRIVADA_DEPLOYER=



{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "strict": true,
    "resolveJsonModule": true,
    "outDir": "scripts/dist",
    "rootDir": "scripts"
  },
  "include": ["scripts/**/*.ts"],
  "exclude": ["node_modules", "frontend", "contracts"]
}
